if __name__ == "__main__":
    parser = argparse.ArgumentParser(
        description="Gera base de lançamentos contabilísticos simulada com fraude."
    )
    parser.add_argument("--n",      type=int,   default=1000,                      help="Total de lançamentos (padrão: 1000)")
    parser.add_argument("--fraude", type=float, default=0.25,                      help="Proporção de fraudes 0.0–0.5 (padrão: 0.25)")
    parser.add_argument("--seed",   type=int,   default=42,                        help="Semente aleatória (padrão: 42)")
    parser.add_argument("--limite", type=float, default=5000.0,                    help="Limite de aprovação para splitting (padrão: 5000)")
    parser.add_argument("--output", type=str,   default="lancamentos_simulados.csv", help="Nome do ficheiro de saída")
    args = parser.parse_args([])

    gerar_base(
        n=args.n,
        proporcao_fraude=args.fraude,
        seed=args.seed,
        limite_aprovacao=args.limite,
        output=args.output,
    )

df = pd.read_csv("lancamentos_simulados.csv")
df = df[df["valor"] > 0].copy()

df["primeiro_digito"] = (
    df["valor"]
    .apply(lambda x: str(x).split(".")[0][0])
    .astype(int)
)

obs = df["primeiro_digito"].value_counts(normalize=True).sort_index() * 100

benford = {d: np.log10(1 + 1/d) * 100 for d in range(1, 10)}
benford_series = pd.Series(benford)

n = len(df)
observed_counts = df["primeiro_digito"].value_counts().sort_index()
expected_counts = benford_series /100 * n

chi2, p_value = stats.chisquare(
    f_obs=observed_counts,
    f_exp=expected_counts,
)

print(f"Chi² = {chi2:.2f} | p-value = {p_value:.4f}")
print("SUSPEITO" if p_value < 0.05 else "CONFORME")

desvios = (obs - benford_series).rename("desvio_pp")
alertas = desvios[desvios.abs() > 3].sort_values(key=abs, ascending=False)
print("\nDigitos com desvio > 3 p.p.:")
print(alertas)

from pdb import line_prefix
fig, ax = plt.subplots(figsize=(10, 6))
x = np.arange(1, 10)
ax.bar(x - 0.2, obs, width=0.4, label='Observado',
       color = ["#E24B4A" if abs(obs[d] - benford[d]) > 5 else
              "#EF9F27" if abs(obs[d] - benford[d]) > 2.5 else
              "#378ADD" for d in range(1, 10)])
ax.plot(x, benford_series, "o--", color="#444", linewidth=1.5,
        label="Esperado Benford", markersize=5)
ax.set_xticks(x)
ax.set_xlabel("primeiro digito")
ax.set_ylabel("frequencia (%)")
ax.set_title(f"lei de benford | x= {chi2:.1f} | p= {p_value:.4f}")
ax.legend()

