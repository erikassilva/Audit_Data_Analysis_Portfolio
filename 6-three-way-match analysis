def criar_faturas(df_po):
  registros = []
  contador = 0
  for i, linha in df_po.iterrows():
    cenario = random.choices(
        population=[
            "normal",
            "preco_inflacionado",
            "quantidade_errada",
            "fatura_duplicada",
            "fatura_sem_gr",
        ],
        weights=[60, 15, 10, 8, 7],
    )[0]

    qtd_fat = linha["quantidade"]
    preco_fat = linha["preco_unit"]

    if cenario == "preco_inflacionado":
      fator_preco = random.uniform(1.05, 1.20)
      preco_fat   = round(preco_fat * fator_preco, 2)

    elif cenario == "normal":
      pass

    elif cenario == "quantidade_errada":
      fator_qtd = random.uniform(1.05, 1.15)
      qtd_fat   = round(qtd_fat * fator_qtd, 0)  

    elif cenario == "fatura_sem_gr":
      pass

    contador += 1
    fatura = {
        "inv_numero" : f"INV-{4024000 + contador}",
        "po_numero"  : linha["po_numero"],
        "fornecedor" : linha["fornecedor"],
        "material"   : linha["material"],
        "qtd_faturada": qtd_fat,
        "preco_fat"  : preco_fat,
        "valor_fat"  : round(qtd_fat * preco_fat, 2),
        "data_fat"   : linha["data_oc"] + timedelta(days=random.randint(10, 40)),
        "cenario"    : cenario,   # coluna auxiliar para validarmos depois
        }

    registros.append(fatura)

    if cenario == "fatura_duplicada":
      contador += 1
      fatura_dup = fatura.copy()
      fatura_dup["inv_numero"] = f"INV-{2024000 + contador}"
      fatura_dup["data_fat"] = fatura["data_fat"] + timedelta(days=random.randint(1,5))   
      registros.append(fatura_dup) 

  df_inv = pd.DataFrame(registros)
  return df_inv

