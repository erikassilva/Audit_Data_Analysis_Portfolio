def criar_ordens_compra(n=50):
  registros = []
  for i in range (n):
    po_numero = f"PO-{202400 + i + 1}"
    fornecedor = random.choice(fornecedores)
    material = random.choice(materiais)
    centro = random.choice(centro_custo)
    quantidade = random.randint(10, 200)
    preco = round(random.uniform(5.0, 500.0), 2)
    valor_total = round(preco * quantidade,2)
    data_po = date(2024, 1, 1) + timedelta(days=random.randint(0, 364))

    linha = {
        "po_numero"  : po_numero,
        "fornecedor" : fornecedor,
        "material"   : material,
        "centro_custo": centro,
        "quantidade" : quantidade,
        "preco_unit" : preco,
        "valor_total": valor_total,
        "data_oc"    : data_po,
    }
    registros.append(linha)

    df = pd.DataFrame(registros)
  
  return df

