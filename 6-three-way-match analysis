def cruzar_tabelas(df_po, df_nr, df_inv):
  nr_agregada = (
      df_nr.groupby(by=["po_numero"])
      .agg(
           qtd_recebida_total = ("quantidade_recebida", "sum"),
           n_recepcoes = ("gr_numero", "count"),

      )
      .reset_index()
  )

  print("NR agregada por OC:")
  print(nr_agregada.head())

  fat_count = (
      df_inv.groupby(by=["po_numero"])
      .agg(
          n_faturas = ("inv_numero", "count"))
      .reset_index()
  )

  df = df_po.merge(
      nr_agregada,
      on = "po_numero",
      how = "left",
    )

  df = df.merge(
      df_inv[[
           "po_numero",
            "inv_numero",
            "qtd_faturada",
            "preco_fat",
            "valor_fat",
            "data_fat",
            "cenario",
      ]],
      on = "po_numero",
      how = "left",
  )

  df = df.merge(
      fat_count,
      on = "po_numero",
      how = "left",
  )

  print(f"\nTabela cruzada: {df.shape[0]} linhas, {df.shape[1]} colunas")
  print(df.head(3))

  return df

df = cruzar_tabelas(df_po, df_nr, df_inv)

total_preco_pct = 3.0
total_qtd_pct = 2.0

def calcular_desvios(df):
  df["desvio_preco_pct"] = (
      (df["preco_fat"] - df["preco_unit"]) / df["preco_unit"] * 100
  ).round(2)

  df["desvio_qtd_pct"] = (
      (df["qtd_faturada"] - df["qtd_recebida_total"]) / df["qtd_recebida_total"] * 100
  ).round(2)

  df["valor_risco"] = (
      df["valor_fat"] - (df["qtd_recebida_total"] * df["preco_unit"])
  ).round(2)

def classificar_linha(linha):
  if pd.isna(linha["qtd_recebida_total"]):
    return "FATURA_SEM_GR"

  if linha["n_faturas"] > 1:
    return "FATURA_DUPLA"

  disc_preco = abs(linha["desvio_preco_pct"]) > total_preco_pct
  disc_qtd   = abs(linha["desvio_qtd_pct"]) > total_qtd_pct

  if disc_preco and disc_qtd:
    return "DISC_PRECO_E_QTD"
  elif disc_preco:
    return "DISC_PRECO"
  elif disc_qtd:
    return "DISC_QTD"

  return "OK"

