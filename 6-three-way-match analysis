def criar_gr(df_po):
  registros = []
  for i, linha in df_po.iterrows():
    if random.random() < 0.10:
      continue
    gr_numero = f"GR-{302400 + i + 1}"
    if random.random() < 0.15:
      fator = random.uniform(0.7, 0.95)
      qtd_recebida = round(linha["quantidade"] * fator, 0)
    else:
      qtd_recebida = round(linha["quantidade"], 0)
    
    dias_depois = random.randint(3,21)
    data_gr = linha["data_oc"] + timedelta(days=dias_depois)

    nr = {
        "gr_numero" : gr_numero,
        "po_numero" : linha["po_numero"],
        "fornecedor" : linha["fornecedor"],
        "material"   : linha["material"],
        "centro_custo": linha["centro_custo"],
        "quantidade_recebida": qtd_recebida,
        "data_gr"   : data_gr,
    }
    registros.append(nr)

    df_nr = pd.DataFrame(registros)

  return df_nr

