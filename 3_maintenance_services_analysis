import pandas as pd
import numpy as np

# Database Preparation

np.random.seed(42)

n_contratos = 30
range_elevadores = (30 , 150)

rows = []

for contrato_id in range(1000, 1000 + n_contratos):
    n_elevadores = np.random.randint(*range_elevadores)
    for elev_id in range(n_elevadores):
      elevador_id = f"{contrato_id}-{elev_id}"
      
      for mes in pd.date_range('2025-01-01', '2025-12-01', freq='MS'):
        planejado = np.random.randint(1, 3)
        realizado = int(round(
            planejado * np.random.uniform(0.7, 1.05)
        ))

        realizado = max(realizado, 0)
        valor_unit = 120
        faturamento = realizado * valor_unit * np.random.uniform(0.95, 1.15)
        rows.append([
            contrato_id, 
            elev_id, 
            mes, 
            planejado, 
            realizado, 
            valor_unit, 
            faturamento])
        
        
servicos = pd.DataFrame(rows, columns=[
    'contrato_id', 
    'elev_id', 
    'mes', 
    'planejado', 
    'realizado', 
    'valor_unit', 
    'faturamento'
    ])


contratos = servicos[['contrato_id']].drop_duplicates()

elevadores = servicos[['contrato_id', 'elev_id']].drop_duplicates()

servicos.to_csv('servicos.csv', index=False)
contratos.to_csv('contratos.csv', index=False)
elevadores.to_csv('elevadores.csv', index=False)

